{
  "name": "ml-torrent-tools",
  "displayName": "ML-Torrent Tools",
  "description": "Status bar actions for checking, running, and uploading ML-Torrent workspaces.",
  "version": "0.0.1",
  "publisher": "MehdiBahlaoui",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mehdi-Bahlaoui/ML-Torrent_VSCODE_Extention.git"
  },
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:mlTorrent.run",
    "onCommand:mlTorrent.upload"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mlTorrent.run",
        "title": "ML-Torrent: Run"
      },
      {
        "command": "mlTorrent.upload",
        "title": "ML-Torrent: Upload"
      }
    ],
    "configuration": {
      "title": "ML-Torrent Tools",
      "properties": {
        "mlTorrent.projectRoot": {
          "type": "string",
          "default": "../dfl",
          "description": "Path to the target project root. Relative paths are resolved from the open workspace folder."
        },
        "mlTorrent.runCommandTemplate": {
          "type": "string",
          "default": "./run.sh ${peers} ${backend}",
          "description": "Shell command template used by Run."
        },
        "mlTorrent.uploadInstallCommandTemplate": {
          "type": "string",
          "default": "cd \"gui/ML-Torrent App\" && ./mobile-app.sh install",
          "description": "Shell command template used by Upload when install is selected."
        },
        "mlTorrent.uploadReleaseCommandTemplate": {
          "type": "string",
          "default": "cd \"gui/ML-Torrent App\" && ./release.sh ${releaseNotes}",
          "description": "Shell command template used by Upload when upload is selected."
        },
        "mlTorrent.arguments": {
          "type": "array",
          "default": [
            {
              "name": "peers",
              "prefix": "",
              "defaultValue": "2"
            },
            {
              "name": "backend",
              "prefix": "--",
              "defaultValue": "gpu",
              "choices": ["none", "cpu", "gpu"]
            },
            {
              "name": "releaseNotes",
              "prefix": "",
              "defaultValue": "Test build"
            },
            {
              "name": "uploadAction",
              "prefix": "",
              "defaultValue": "install",
              "choices": ["install", "upload"]
            }
          ],
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Placeholder name without ${}."
              },
              "prefix": {
                "type": "string",
                "description": "Command prefix added before the value. Examples: empty string, -e, --, -s=."
              },
              "defaultValue": {
                "type": "string",
                "description": "Default value shown when prompting."
              },
              "choices": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Optional fixed list of choices for a menu-based prompt."
              }
            }
          },
          "description": "Argument definitions used by command placeholders. Each ${name} can have a prefix, a default value, and optional choices so prompts stay compact and predictable."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.89.0",
    "typescript": "^5.4.5"
  }
}
